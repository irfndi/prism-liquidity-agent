# ── Required ──────────────────────────────────────────────
# These must be set for the agent to function.
HELIUS_API_KEY=your-helius-api-key
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# │  WALLET_PRIVATE_KEY  │  only needed for live (non-paper) trading
# │                      │  generate one via: prism wallet generate

# ── Strategy ──────────────────────────────────────────────
# All vars have sensible defaults; override to tune behavior.

# Paper trading: simulated positions (true) or real on-chain (false)
PAPER_TRADING=true

# Pool scan interval in milliseconds (default: 600000 = 10 min)
SCAN_INTERVAL_MS=600000

# Skip pools below this TVL (USD)
MIN_POOL_TVL_USD=50000

# Minimum fee / impermanent loss ratio to hold a position
MIN_FEE_IL_RATIO=1.2

# TVL drop (as fraction) that triggers an exit decision
TVL_DROP_EXIT_PCT=0.30

# Minimum volume authenticity score (0-1) to consider a pool
VOLUME_AUTH_THRESHOLD=0.70

# Maximum positions held concurrently
MAX_CONCURRENT_POSITIONS=5

# Minimum confidence (0-1) for any decision to pass risk gates
CONFIDENCE_THRESHOLD=0.65

# Minimum time (ms) between rebalances of the same pool
MIN_REBALANCE_INTERVAL_MS=86400000

# Minimum net benefit (USD) required to justify a rebalance
MIN_REBALANCE_NET_BENEFIT_USD=10

# Paper trading starting portfolio balance (USD)
PAPER_PORTFOLIO_USD=10000

# Minimum bin utilization (0-1) to hold a position
MIN_BIN_UTILIZATION=0.30

# Maximum bin range width (in bins) for rebalance
MAX_REBALANCE_RANGE_BINS=50

# Pools to watch (comma-separated Meteora DLMM pool addresses)
WATCHLIST_POOLS=

# ── Risk ──────────────────────────────────────────────────
# Gates that block execution before anything reaches on-chain.

# Stop-loss: exit position if drawdown exceeds this fraction
STOP_LOSS_PCT=0.15

# Trailing stop: exit when price drops this fraction from peak
TRAILING_STOP_PCT=0.10

# Grace period (cycles) before acting on out-of-range position
OOR_GRACE_PERIOD_CYCLES=3

# Minimum interval (ms) between fee claims
FEE_CLAIM_INTERVAL_MS=86400000

# ── Features ──────────────────────────────────────────────
# Optional capabilities that can be toggled on.

# F1: Gas-aware rebalancing — skip rebalance when gas cost > N days of position fees
REBALANCE_GAS_COST_SOL=0.01
SOL_PRICE_USD=150
GAS_AWARE_MIN_DAYS_OF_FEES_PAID_AHEAD=3

# F2: Volatility-adjusted range sizing — exit to wallet when stddev of active bin exceeds threshold
VOLATILITY_EXIT_STDDEV=5
VOLATILITY_LOOKBACK_SNAPSHOTS=12
VOLATILITY_WIDE_HALF_WIDTH_BINS=50

# F3: Fee compounding / auto-reinvest — claim fees and redeposit when gas-efficient
AUTO_COMPOUND_FEES=false
MIN_COMPOUND_FEES_USD=0.5
COMPOUND_GAS_BUFFER_USD=0.05

# F4: OOR recovery prediction — hold when mean-reversion probability is high
OOR_RECOVERY_LOOKBACK_CYCLES=10
OOR_RECOVERY_HOLD_THRESHOLD=0.6
OOR_RECOVERY_FORCE_REBALANCE_THRESHOLD=0.2

# F5: Multi-pool allocation — split exposure across N pools with per-pool cap
MAX_PER_POOL_ALLOCATION_PCT=0.4
MAX_OPEN_POSITIONS=3

# F6: Paper-trading validation — require N paper days before live ENTER
PAPER_VALIDATION_MIN_DAYS=7
PAPER_VALIDATION_ENFORCE=false

# Embedding backend: "fallback" (pure-JS, no download) or "onnx"
EMBEDDINGS_BACKEND=fallback

# Auto-discover pools when WATCHLIST_POOLS is empty
ENABLE_POOL_DISCOVERY=false

# Minimum TVL (USD) for auto-discovered pools
DISCOVERY_MIN_TVL_USD=100000

# Minimum fee ratio for auto-discovered pools
DISCOVERY_MIN_FEE_RATIO=1.5

# Dump full pool state snapshots to DB every cycle (paper only)
ENABLE_SNAPSHOT_CAPTURE=false

# ── Agent runtime overlay ──────────────────────────────────
# Optional: let a local agent runtime (Hermes via ACP, OpenClaw via Gateway)
# review decisions and receive proactive check-ins. No remote LLM API keys.

# Enable agentic overlay (default: false)
AGENTIC_MODE=false

# Runtime to use: "auto" | "hermes" | "openclaw" | "none"
AGENT_RUNTIME=auto

# Hermes ACP settings
AGENT_ACP_ARGS=acp
AGENT_ACP_COMMAND=hermes

# OpenClaw Gateway settings
AGENT_GATEWAY_TOKEN=
AGENT_GATEWAY_URL=ws://127.0.0.1:18789

# Agent prompt/check-in timeout in milliseconds
AGENT_PROMPT_TIMEOUT_MS=15000

# Periodic check-in interval in milliseconds (default: 1h)
AGENT_CHECKIN_INTERVAL_MS=3600000

# Send check-ins on ENTER/EXIT/REBALANCE events
AGENT_CHECKIN_ON_EVENTS=true

# Include recent memory warnings and decisions in check-ins
AGENT_CHECKIN_INCLUDE_HISTORY=true

# Max positions to include in check-in summary
AGENT_CHECKIN_MAX_POSITIONS=10

# One-way alert webhooks (optional; empty = disabled)
AGENT_OPENCLAW_WEBHOOK_URL=
AGENT_HERMES_API_URL=

# Local agent HTTP status API (0 = disabled; default disabled unless agent overlay is on)
AGENT_HTTP_PORT=0

# MCP server for agent runtime tool discovery (default false; enable only when stdout is isolated)
AGENT_MCP_ENABLED=false

# ── Updates ───────────────────────────────────────────────
# Auto-update settings for the R2 / GitHub release mechanism.

# Enable automatic update checks
AUTO_UPDATE=true

# Update check interval in milliseconds (default: 21600000 = 6h)
UPDATE_CHECK_INTERVAL_MS=21600000

# Release channel: "stable" | "beta" | "dev"
UPDATE_CHANNEL=stable

# GitHub repo for fallback release lookup
UPDATE_GITHUB_REPO=irfndi/prism-liquidity-agent

# R2 public URL for primary release distribution
UPDATE_R2_PUBLIC_URL=https://r2.prism-agent.com

# Allow updates on dirty working tree (dev use only)
UPDATE_ALLOW_DIRTY=false

# ── GitHub / Feedback ─────────────────────────────────────
# Required for filing GitHub issues from the feedback command.

# Personal access token with repo scope (optional, local without)
GITHUB_TOKEN=

# Target repo for filed feedback issues
GITHUB_REPO=irfndi/prism-liquidity-agent

# Set to "true" to disable anonymous feedback submission
PRISM_FEEDBACK_OPT_OUT=false

# ── Paths ─────────────────────────────────────────────────
# Override default file locations.

# SQLite database path
SQLITE_DB_PATH=./prism.db

# Override bundled deployer blacklist (JSON array of addresses)
# DEPLOYER_BLACKLIST_PATH=./engine/data/deployer-blacklist.json

# Override bundled token blacklist (JSON array of addresses)
# TOKEN_BLACKLIST_PATH=./engine/data/token-blacklist.json
