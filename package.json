{
  "name": "prism-liquidity-agent",
  "version": "0.0.2",
  "description": "Autonomous liquidity agent for Solana pools (currently Meteora DLMM)",
  "keywords": [
    "ai-agent",
    "autonomous",
    "claude",
    "defi",
    "dlmm",
    "effect-ts",
    "liquidity",
    "meteora",
    "rebalancing",
    "solana"
  ],
  "license": "MIT",
  "bin": {
    "prism": "./scripts/prism.sh"
  },
  "type": "module",
  "scripts": {
    "start": "bun dist/index.mjs",
    "dev": "bun run --watch engine/index.ts",
    "build": "bunx --bun tsdown",
    "setup": "bun run ops/setup.ts",
    "setup:env": "bun run scripts/postinstall.js",
    "postinstall": "bun run scripts/postinstall.js || true",
    "backtest": "bun run ops/backtest.ts",
    "test": "bunx --bun vitest run",
    "test:watch": "bunx --bun vitest",
    "lint": "tsc --noEmit && oxlint engine ops bench cli",
    "format": "oxfmt --write engine ops bench cli",
    "format:check": "oxfmt --check engine ops bench cli",
    "coverage": "bunx --bun vitest run --coverage"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@meteora-ag/dlmm": "^1.9.10",
    "@solana/web3.js": "^1.98.4",
    "@xenova/transformers": "^2.17.2",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "effect": "^3.21.2",
    "semver": "^7.8.1",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.8",
    "bun-types": "^1.2.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
