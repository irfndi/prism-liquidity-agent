{
  "name": "prism-dlmm",
  "version": "1.0.0",
  "description": "Autonomous DLMM rebalancing agent for Meteora pools on Solana",
  "type": "module",
  "bin": {
    "prism": "./cli/index.ts"
  },
  "scripts": {
    "start": "node dist/engine/index.js",
    "dev": "bun run --watch engine/index.ts",
    "build": "bunx --bun tsdown",
    "setup": "bun run ops/setup.ts",
    "backtest": "bun run ops/backtest.ts",
    "test": "bunx --bun vitest run",
    "test:watch": "bunx --bun vitest",
    "lint": "tsc --noEmit && oxlint engine ops bench cli",
    "format": "oxfmt --write engine ops bench cli",
    "format:check": "oxfmt --check engine ops bench cli",
    "coverage": "bunx --bun vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@clack/prompts": "^1.5.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@jup-ag/api": "^6.0.48",
    "@meteora-ag/dlmm": "^1.9.10",
    "@solana/web3.js": "^1.98.4",
    "@xenova/transformers": "^2.17.2",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "effect": "^3.21.2",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "bun-types": "^1.2.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tsdown": "^0.22.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "solana",
    "meteora",
    "dlmm",
    "liquidity",
    "ai-agent",
    "claude",
    "defi",
    "rebalancing",
    "autonomous",
    "mcp",
    "effect-ts"
  ],
  "license": "MIT"
}
